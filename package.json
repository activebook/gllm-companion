{
  "name": "gllm-companion",
  "displayName": "gllm Companion",
  "icon": "images/icon.png",
  "publisher": "Activebook",
  "description": "Companion extension for gllm — brings AI-suggested code changes into VSCode as native inline diffs, and enriches gllm sessions with open editor context, cursor position, and selected text.",
  "version": "0.0.7",
  "repository": {
    "type": "git",
    "url": "https://github.com/activebook/gllm-companion"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gllm-companion.run",
        "title": "Run",
        "category": "gllm"
      },
      {
        "command": "gllm-companion.diff.accept",
        "title": "Accept Diff",
        "category": "gllm",
        "icon": "$(check)"
      },
      {
        "command": "gllm-companion.diff.cancel",
        "title": "Cancel Diff",
        "category": "gllm",
        "icon": "$(close)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "gllm-companion.diff.accept",
          "group": "navigation",
          "when": "isInDiffEditor && gllm-companion.activeDiff"
        },
        {
          "command": "gllm-companion.diff.cancel",
          "group": "navigation",
          "when": "isInDiffEditor && gllm-companion.activeDiff"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gllm-companion.diff.accept",
        "key": "ctrl+s",
        "mac": "cmd+s",
        "when": "isInDiffEditor && gllm-companion.activeDiff"
      },
      {
        "command": "gllm-companion.diff.cancel",
        "key": "escape",
        "mac": "escape",
        "when": "isInDiffEditor && gllm-companion.activeDiff"
      }
    ]
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {}
}